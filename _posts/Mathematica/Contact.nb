 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "=", "50"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqns", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"F1", "'"}], "[", "s", "]"}], "-", 
       RowBox[{
        RowBox[{"\[Omega]", "[", "s", "]"}], " ", 
        RowBox[{"F2", "[", "s", "]"}]}], "-", 
       RowBox[{"g", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "[", "s", "]"}], "]"}]}]}], "==", "0"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"F2", "'"}], "[", "s", "]"}], "+", 
       RowBox[{
        RowBox[{"\[Omega]", "[", "s", "]"}], " ", 
        RowBox[{"F1", "[", "s", "]"}]}], "-", 
       RowBox[{"g", " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "[", "s", "]"}], "]"}]}]}], "==", "0"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"B", " ", 
        RowBox[{
         RowBox[{"\[Omega]", "'"}], "[", "s", "]"}]}], "+", 
       RowBox[{"F2", "[", "s", "]"}]}], "==", "0"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "'"}], "[", "s", "]"}], "==", 
      RowBox[{"\[Omega]", "[", "s", "]"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "'"}], "[", "s", "]"}], "==", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "[", "s", "]"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"y", "'"}], "[", "s", "]"}], "==", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "[", "s", "]"}], "]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"BC", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "[", "0", "]"}], "==", "0"}], ",", 
    RowBox[{
     RowBox[{"\[Theta]", "[", "0", "]"}], "==", "0"}], ",", 
    RowBox[{
     RowBox[{"y", "[", "0", "]"}], "==", "0"}], ",", 
    RowBox[{
     RowBox[{"F1", "[", "L", "]"}], "==", "0"}], ",", 
    RowBox[{
     RowBox[{"F2", "[", "L", "]"}], "==", "0"}], ",", 
    RowBox[{
     RowBox[{"\[Omega]", "[", "L", "]"}], "==", "0"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", 
