Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"GetSol", "[", 
    RowBox[{"L_", ",", "g_", ",", "B_", ",", "R_", ",", 
     RowBox[{"\[Phi]c_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"eqns", ",", "BC", ",", "sol"}], "}"}], ",", 
     RowBox[{
      RowBox[{"eqns", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"F1", "'"}], "[", "s", "]"}], "-", 
           RowBox[{
            RowBox[{"\[Omega]", "[", "s", "]"}], " ", 
            RowBox[{"F2", "[", "s", "]"}]}], "-", 
           RowBox[{"g", " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"\[Theta]", "[", "s", "]"}], "]"}]}]}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"F2", "'"}], "[", "s", "]"}], "+", 
           RowBox[{
            RowBox[{"\[Omega]", "[", "s", "]"}], " ", 
            RowBox[{"F1", "[", "s", "]"}]}], "-", 
           RowBox[{"g", " ", 
            RowBox[{"Cos", "[", 
             RowBox[{"\[Theta]", "[", "s", "]"}], "]"}]}]}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"B", " ", 
            RowBox[{
             RowBox[{"\[Omega]", "'"}], "[", "s", "]"}]}], "+", 
           RowBox[{"F2", "[", "s", "]"}]}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Theta]", "'"}], "[", "s", "]"}], "==", 
          RowBox[{"\[Omega]", "[", "s", "]"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"x", "'"}], "[", "s", "]"}], "==", 
          RowBox[{"Cos", "[", 
           RowBox[{"\[Theta]", "[", "s", "]"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"y", "'"}], "[", "s", "]"}], "==", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "[", "s", "]"}], "]"}]}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"BC", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "[", "0", "]"}], "==", 
          RowBox[{"R", " ", 
           RowBox[{"Sin", "[", "\[Phi]c", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{"y", "[", "0", "]"}], "==", 
          RowBox[{"R", " ", 
           RowBox[{"Cos", "[", "\[Phi]c", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{"\[Theta]", "[", "0", "]"}], "==", 
          RowBox[{"-", "\[Phi]c"}]}], ",", 
         RowBox[{
          RowBox[{"F1", "[", 
           RowBox[{"L", "-", 
            RowBox[{"R", " ", "\[Phi]c"}]}], "]"}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"F2", "[", 
           RowBox[{"L", "-", 
            RowBox[{"R", " ", "\[Phi]c"}]}], "]"}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"\[Omega]", "[", 
           RowBox[{"L", "-", 
            RowBox[{"R", " ", "\[Phi]c"}]}], "]"}], "==", "0"}]}], "}"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"sol", "=", 
       RowBox[{"NDSolve", "[", 
        RowBox[{
         RowBox[{"Join", "[", 
          RowBox[{"eqns", ",", "BC"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{
          "x", ",", "y", ",", "\[Theta]", ",", "\[Omega]", ",", "F1", ",", 
           "F2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"s", ",", "0", ",", 
           RowBox[{"L", "-", 
            RowBox[{"R", " ", "\[Phi]c"}]}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "sol"}]}], "]"}]}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"GetResidual", "[", 
   RowBox[{"L_", ",", "g_", ",", "B_", ",", "R_", ",", 
    RowBox[{"\[Phi]c_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "sol", "}"}], ",", 
    RowBox[{
     RowBox[{"sol", "=", 
      RowBox[{"GetSol", "[", 
       RowBox[{"L", ",", "g", ",", "B", ",", "R", ",", "\[Phi]c"}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"F1", "[", "s", "]"}], "/.", " ", 
          RowBox[{"sol", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "/.", " ", 
         RowBox[{"s", "->", "0"}]}], ")"}], "-", 
       RowBox[{"g", " ", "R", " ", 
        RowBox[{"Cos", "[", "\[Phi]c", "]"}]}]}], ")"}]}]}], 
   "]"}]}], "\[IndentingNewLine]"}], "Input",
