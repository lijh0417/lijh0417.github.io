Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"r", ",", "R", ",", "k"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"p", "[", 
    RowBox[{"\[Theta]_", ",", "k_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"R", "-", 
        RowBox[{"r", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"k", " ", "\[Theta]"}], "]"}]}]}], ")"}], 
      RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"R", "-", 
        RowBox[{"r", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"k", " ", "\[Theta]"}], "]"}]}]}], ")"}], 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"r", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"k", " ", "\[Theta]"}], "]"}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ds", "[", "\[Theta]_", "]"}], ":=", 
   SqrtBox[
    RowBox[{
     RowBox[{
      RowBox[{"k", "^", "2"}], 
      RowBox[{"r", "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"R", "-", 
        RowBox[{"r", " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"k", " ", "\[Theta]"}], "]"}]}]}], ")"}], "^", "2"}]}]]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T1", "=", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"p", "[", 
       RowBox[{"\[Theta]", ",", "k"}], "]"}], ",", "\[Theta]"}], "]"}], "/", 
    RowBox[{"ds", "[", "\[Theta]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", "0"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R", "=", "5"}], ";", 
  RowBox[{"r", "=", "0.5"}], ";", 
  RowBox[{"\[Phi]", "=", 
   RowBox[{"5", " ", "\[Theta]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Show", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"R", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
         RowBox[{"R", " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "0", ",", 
         RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
       RowBox[{"PlotLabel", "->", "None"}], ",", 
       RowBox[{"Mesh", "->", "None"}], ",", 
       RowBox[{"Boxed", "->", "False"}], ",", 
       RowBox[{"AxesLabel", "->", "None"}], ",", 
       RowBox[{"Axes", "->", "False"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Pink", ",", 
          RowBox[{"Opacity", "[", "0.6", "]"}]}], "}"}]}]}], "]"}], ",", 
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"R", "-", 
            RowBox[{"r", "*", 
             RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], ")"}], 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"R", "-", 
            RowBox[{"r", "*", 
             RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], ")"}], 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "0", ",", 
         RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Blue", ",", "Thick"}], "}"}]}]}], "]"}]}], "}"}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"T", ".", "T1"}], ",", 
    RowBox[{
     RowBox[{"R", ">", "0"}], "&&", 
     RowBox[{"r", ">", "0"}], "&&", 
     RowBox[{"k", ">", "0"}], "&&", 
     RowBox[{"\[Theta]", ">", "0"}]}]}], "]"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"f1", "[", 
     RowBox[{
      RowBox[{"R_", "?", "NumericQ"}], ",", 
      RowBox[{"r_", "?", "NumericQ"}], ",", 
      RowBox[{"k_", "?", "NumericQ"}]}], "]"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{"ds", "[", "\[Theta]", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "0", ",", 
          RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], "-", 
      RowBox[{"1", "\[IndentingNewLine]", 
       RowBox[{"f2", "[", 
        RowBox[{
         RowBox[{"R_", "?", "NumericQ"}], ",", 
         RowBox[{"r_", "?", "NumericQ"}], ",", 
         RowBox[{"k_", "?", "NumericQ"}]}], "]"}]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"2", "r", " ", "R"}], "-", 
       RowBox[{"\[CapitalLambda]", " ", 
        RowBox[{"NIntegrate", "[", 
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"ds", "[", "\[Theta]", "]"}], ",", "r"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Theta]", ",", "0", ",", 
            RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", 
        RowBox[{"f3", "[", 
         RowBox[{
          RowBox[{"R_", "?", "NumericQ"}], ",", 
          RowBox[{"r_", "?", "NumericQ"}], ",", 
          RowBox[{"k_", "?", "NumericQ"}]}], "]"}]}]}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"r", " ", "^", "2"}], "-", 
        RowBox[{"\[CapitalLambda]", " ", 
         RowBox[{"NIntegrate", "[", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"ds", "[", "\[Theta]", "]"}], ",", "R"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Theta]", ",", "0", ",", 
             RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", 
         "kk"}]}], "=", "2"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
